<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Content Area Placeholder -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
    android:id="@+id/bottomNavContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="0dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="8dp">
        <ImageView
            android:id="@+id/navHomeIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_home"
            app:tint="@color/slate_400" />
        <TextView
            android:id="@+id/navHomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Home"
            android:textColor="@color/slate_400"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Quizzes -->
    <LinearLayout
        android:id="@+id/navQuizzes"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="8dp">
        <ImageView
            android:id="@+id/navQuizzesIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_quiz"
            app:tint="@color/slate_400" />
        <TextView
            android:id="@+id/navQuizzesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Quizzes"
            android:textColor="@color/slate_400"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Leagues -->
    <LinearLayout
        android:id="@+id/navLeagues"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="8dp">
        <ImageView
            android:id="@+id/navLeaguesIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_leaderboard"
            app:tint="@color/slate_400" />
        <TextView
            android:id="@+id/navLeaguesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Leagues"
            android:textColor="@color/slate_400"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Profile -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="8dp">
        <ImageView
            android:id="@+id/navProfileIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/img"
            app:tint="@color/slate_400" />
        <TextView
            android:id="@+id/navProfileLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Profile"
            android:textColor="@color/slate_400"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

</LinearLayout>
</com.google.android.material.card.MaterialCardView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>