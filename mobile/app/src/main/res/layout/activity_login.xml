<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/high_stakes_header" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Logo Section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/white_blur_rect"
                    android:padding="16dp"
                    android:rotation="3">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_quiz"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-black"
                    android:text="EduQuiz"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:letterSpacing="-0.02" />
            </LinearLayout>

            <!-- Login Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="24dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/slate_50">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="sans-serif-bold"
                        android:text="Welcome back!"
                        android:textColor="@color/slate_800"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"
                        android:text="Sign in to continue your journey"
                        android:textColor="@color/slate_500"
                        android:textSize="14sp" />

                    <!-- Username Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:layout_marginLeft="4dp"
                        android:fontFamily="sans-serif-black"
                        android:text="USERNAME"
                        android:textColor="@color/slate_400"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <EditText
                        android:id="@+id/usernameInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/field_background"
                        android:hint="Enter your username"
                        android:paddingHorizontal="20dp"
                        android:textColor="@color/slate_800"
                        android:textColorHint="@color/slate_300"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Password Field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginLeft="4dp"
                        android:fontFamily="sans-serif-black"
                        android:text="PASSWORD"
                        android:textColor="@color/slate_400"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        app:endIconMode="password_toggle"
                        app:boxBackgroundMode="none"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/passwordInput"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/field_background"
                            android:hint="Enter your password"
                            android:inputType="textPassword"
                            android:paddingStart="20dp"
                            android:paddingEnd="40dp"
                            android:textColor="@color/slate_800"
                            android:textColorHint="@color/slate_300"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-bold"
                        android:text="Forgot password?"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />

                    <!-- Login Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/loginBtn"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="32dp"
                        android:text="Sign In"
                        android:textAllCaps="false"
                        android:fontFamily="sans-serif-black"
                        android:textSize="16sp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="20dp"
                        android:elevation="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Registration Footer -->
            <TextView
                android:id="@+id/registerLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:fontFamily="sans-serif-medium"
                android:text="Don't have an account? Create free"
                android:textColor="@color/slate_500"
                android:textSize="14sp" />

        </LinearLayout>
    </RelativeLayout>
</ScrollView>