<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/quiz_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Number badge -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/numberBadge"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/quiz_purple_light"
            android:layout_marginEnd="14dp">

            <TextView
                android:id="@+id/quizNumber"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/quiz_purple"
                android:gravity="center" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Title + description -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/quizTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quiz Title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/quiz_text_primary"
                android:layout_marginBottom="3dp" />

            <TextView
                android:id="@+id/quizDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="12sp"
                android:textColor="@color/quiz_text_secondary"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Action button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/quizActionButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="View"
            android:textSize="12sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/quiz_purple_light"
            android:textColor="@color/quiz_purple"
            app:cornerRadius="100dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>