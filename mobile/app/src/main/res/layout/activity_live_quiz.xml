<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF4EC"
    android:padding="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/questionCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Question 1/5"
            android:textSize="14sp"
            android:textColor="#5F5E5A"/>

        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 0 pts"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FF6B00"/>

    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/questionProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginBottom="24dp"
        android:progressTint="#FF6B00"
        android:progressBackgroundTint="#FFD4B0"
        android:max="100"
        android:progress="0"/>

    <!-- Question card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeColor="#FFD4B0"
        app:strokeWidth="1dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/questionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="Question goes here?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C2C2A"
            android:lineSpacingMultiplier="1.3"/>

    </androidx.cardview.widget.CardView>

    <!-- Options -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/option1Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Option A"
                android:textSize="15sp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#FFD4B0"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                android:textColor="#2C2C2A"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/option2Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Option B"
                android:textSize="15sp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#FFD4B0"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                android:textColor="#2C2C2A"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/option3Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Option C"
                android:textSize="15sp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#FFD4B0"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                android:textColor="#2C2C2A"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/option4Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Option D"
                android:textSize="15sp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#FFD4B0"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                android:textColor="#2C2C2A"/>

        </LinearLayout>
    </ScrollView>

    <!-- Next button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/nextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Next →"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:layout_marginTop="12dp"
        app:backgroundTint="#FF6B00"
        app:cornerRadius="12dp"
        android:enabled="false"/>

</LinearLayout>