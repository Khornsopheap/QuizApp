<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Progress Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:id="@+id/questionCountText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Question 1 / 10"
                android:textColor="@color/white_60"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/scoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pts: 100"
                android:textColor="@color/accent_amber"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/questionProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:progressDrawable="@drawable/custom_progress_bar"
            android:max="100"
            android:progress="25" />
    </LinearLayout>

    <!-- Question Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="24dp"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/EduQuizCard"
            android:layout_marginBottom="32dp">
            <TextView
                android:id="@+id/questionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:text="What is the capital city of France?"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/on_background"
                android:lineSpacingExtra="4dp" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/option1Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Option A"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="@color/on_surface"
                app:strokeColor="@color/outline_variant"
                android:paddingVertical="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/option2Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Option B"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="@color/on_surface"
                app:strokeColor="@color/outline_variant"
                android:paddingVertical="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/option3Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Option C"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="@color/on_surface"
                app:strokeColor="@color/outline_variant"
                android:paddingVertical="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/option4Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Option D"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="@color/on_surface"
                app:strokeColor="@color/outline_variant"
                android:paddingVertical="16dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:text="Continue"
            app:backgroundTint="@color/primary"
            app:cornerRadius="100dp" />

    </LinearLayout>

</LinearLayout>
